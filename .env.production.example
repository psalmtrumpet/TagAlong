# ============================================================
# TagAlong Production Environment Variables
# Copy this file to .env on your VPS and fill in the values
# ============================================================

# --- Docker Registry (optional, leave blank to build locally) ---
DOCKER_REGISTRY=
TAG=latest

# --- VPS / Domain ---
# Your VPS public IP or domain name (used by Ocelot gateway)
VPS_HOST=https://www.tlimc.net

# --- SQL Server ---
SA_PASSWORD=Password1@

# Database connection strings (all point to the sqlserver container)
IDENTITY_DB_CONNECTION=Server=sqlserver;Database=tagalong_identity;User Id=sa;Password=Password1@;TrustServerCertificate=True
USER_DB_CONNECTION=Server=sqlserver;Database=tagalong_user;User Id=sa;Password=Password1@;TrustServerCertificate=True
TRIP_DB_CONNECTION=Server=sqlserver;Database=tagalong_trip;User Id=sa;Password=Password1@;TrustServerCertificate=True
PACKAGE_DB_CONNECTION=Server=sqlserver;Database=tagalong_package;User Id=sa;Password=Password1@;TrustServerCertificate=True
PAYMENT_DB_CONNECTION=Server=sqlserver;Database=tagalong_payment;User Id=sa;Password=Password1@;TrustServerCertificate=True
NOTIFICATION_DB_CONNECTION=Server=sqlserver;Database=tagalong_notification;User Id=sa;Password=Password1@;TrustServerCertificate=True
MESSAGING_DB_CONNECTION=Server=sqlserver;Database=tagalong_messaging;User Id=sa;Password=Password1@;TrustServerCertificate=True
REVIEW_DB_CONNECTION=Server=sqlserver;Database=tagalong_review;User Id=sa;Password=Password1@;TrustServerCertificate=True
REPORT_DB_CONNECTION=Server=sqlserver;Database=tagalong_report;User Id=sa;Password=Password1@;TrustServerCertificate=True
CONFIGURATION_DB_CONNECTION=Server=sqlserver;Database=tagalong_configuration;User Id=sa;Password=Password1@;TrustServerCertificate=True

# --- RabbitMQ ---
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=Password1@
RABBITMQ_HOST=rabbitmq
RABBITMQ_CONNECTION=amqp://admin:Password1%40@rabbitmq:5672

# --- Redis ---
REDIS_CONNECTION=redis:6379

# --- JWT ---
JWT_SECRET_KEY=3f6a8d4e-9c2b-4a7f-b1e2-6d8f9a1c0b34
JWT_ISSUER=TagAlong
JWT_AUDIENCE=TagAlong.Mobile

# --- Google OAuth ---
GOOGLE_CLIENT_ID=93091767508-k8qfh3q0kc9mtr0r5k9moldsakq6birb.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret   # ← fill this in

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=AIzaSyAIET0mLzoyUxTN0rKEsIDE6pGgmFGRLS4

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Platform Settings ---
PLATFORM_FEE_PERCENTAGE=10

# Mail Service (for tagalong.delivery waitlist form)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@tlimc.net
SMTP_PASS=your-email-password-here
