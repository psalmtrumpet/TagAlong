# Docker Registry
DOCKER_REGISTRY=your-registry.azurecr.io
TAG=latest

# Database Connections (Use Azure SQL Database or your SQL Server instance)
IDENTITY_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_identity;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
USER_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_user;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
TRIP_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_trip;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
PACKAGE_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_package;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
PAYMENT_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_payment;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
NOTIFICATION_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_notification;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
MESSAGING_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_messaging;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
REVIEW_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_review;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
REPORT_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_report;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True
CONFIGURATION_DB_CONNECTION=Server=your-sql-server.database.windows.net;Database=tagalong_configuration;User Id=your-username;Password=your-password;TrustServerCertificate=True;Encrypt=True

# RabbitMQ (Use Azure Service Bus or CloudAMQP)
RABBITMQ_HOST=your-rabbitmq-host.cloudamqp.com
RABBITMQ_USER=your-rabbitmq-user
RABBITMQ_PASSWORD=your-rabbitmq-password

# Redis (Use Azure Cache for Redis)
REDIS_CONNECTION=your-redis.redis.cache.windows.net:6380,password=your-redis-password,ssl=True,abortConnect=False

# JWT Configuration
JWT_SECRET_KEY=YourSuperSecretKeyForProductionMakeItVeryLongAndSecure64CharsMinimum
JWT_ISSUER=TagAlong
JWT_AUDIENCE=TagAlong

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe Payment (Optional)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
